{
  "name": "jadob/scribe",
  "description": "Event Sourcing Library",
  "license": "MIT",
  "type": "library",
  "require": {
    "php": "^8.4",
    "ramsey/uuid": "^4.9",
    "ext-openssl": "*",
    "doctrine/dbal": "^4.4"
  },
  "autoload": {
    "psr-4": {
      "Jadob\\Scribe\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Jadob\\Scribe\\": "tests"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^12",
    "friendsofphp/php-cs-fixer": "^3.95",
    "vimeo/psalm": "^6",
    "phpstan/phpstan": "^2.2",
    "rector/rector": "^2.5"
  }
